APP_NAME="Cwt Academy"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cwt_academy
DB_USERNAME=cwt
DB_PASSWORD=cwt_password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=strict
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 (S3-compatible object storage for payment proofs)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# CDN / Asset URL for multi-node deployments (CloudFront/Cloudflare).
# When set, Laravel asset() and Storage::url() will prefix with this URL.
# Leave empty to serve assets directly from the app server.
ASSET_URL=
CDN_URL=
IMAGE_CDN_URL=

# ---------------------------------------------------------------------------
# READ REPLICA (optional — set DB_READ_HOST to enable read/write splitting)
# ---------------------------------------------------------------------------
DB_READ_HOST=
DB_READ_PORT=3306
DB_READ_DATABASE=
DB_READ_USERNAME=
DB_READ_PASSWORD=

VITE_APP_NAME="${APP_NAME}"

ADMIN_DEFAULT_EMAIL=admin@cwtacademy.local
# Default admin password used by seeders / CreateAdminUser command.
# Must satisfy the password policy (12+ chars, mixed case, digit, symbol).
# Change this before running in any environment; never use the placeholder in production.
ADMIN_DEFAULT_PASSWORD=ChangeMeBeforeDeployment123!
# Production: do not seed with defaults. Use php artisan admin:create instead.

PAYMENT_PROOF_MAX_MB=5

# Security hardening (2026)
# Trusted proxies for TrustProxies middleware. Use comma-separated IPs.
# In production behind Cloudflare or ALB, set to the proxy IP range.
TRUSTED_PROXIES=

# Force HTTPS generation and redirects (production only).
FORCE_HTTPS=false

# CSP report URI for nonce-based strict CSP.
CSP_REPORT_URI=

# CAPTCHA: turnstile | math | none
#   turnstile = Cloudflare Turnstile (requires site/secret keys below)
#   math      = Self-hosted math question (no external API needed)
#   none      = Disabled (default for local development)
CAPTCHA_DRIVER=math
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google reCAPTCHA v3 (login/register bot protection). Leave empty to disable.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Social Login (Laravel Socialite). Leave empty to disable a provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/auth/github/callback"

# WebAuthn / Passkey (laragear/webauthn)
# WEBAUTHN_ID must be a bare host (no scheme/port). The browser uses it to bind
# credentials to your origin. Using "https://example.com" will break the
# ceremony. Use the exact production host, or leave empty to fall back to the
# APP_URL host.
WEBAUTHN_NAME="${APP_NAME}"
WEBAUTHN_ID=""

# WEBAUTHN_ORIGINS is a comma-separated list of full origins (with scheme) that
# are allowed to authenticate. In production this should be exactly the
# canonical HTTPS URL. Leave empty to fall back to APP_URL.
WEBAUTHN_ORIGINS=""

# Audit log retention in days (default 90)
AUDIT_LOG_RETENTION_DAYS=90

# ---------------------------------------------------------------------------
# ERROR TRACKING & OBSERVABILITY
# ---------------------------------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.01

# Health check secret token (used by external monitors)
HEALTH_CHECK_TOKEN=


# Argon2id hashing (recommended for PHP 8.3+)
# BCRYPT_ROUNDS is deprecated in favour of ARGON2_ below.
ARGON2_MEMORY=65536
ARGON2_THREADS=1
ARGON2_TIME=4

# ---------------------------------------------------------------------------
# PRODUCTION HARDENING CHECKLIST
# ---------------------------------------------------------------------------
# Before deploying to production, ensure ALL of the following are set:
#
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://your-domain.com
#   SESSION_SECURE_COOKIE=true
#   SESSION_ENCRYPT=true
#   SESSION_SAME_SITE=strict
#   FORCE_HTTPS=true
#   TRUSTED_PROXIES=your-proxy-ip-range
#
#   Remove or unset ADMIN_DEFAULT_PASSWORD after initial seeding.
#   Use php artisan admin:create for all admin accounts in production.
#
#   Set strong database credentials.
#
#   Error tracking (Sentry):
#       SENTRY_LARAVEL_DSN=https://xxx@o0.ingest.sentry.io/0
#       SENTRY_RELEASE=1.0.0
#       SENTRY_TRACES_SAMPLE_RATE=0.1
#
#   Health check token (keep secret):
#       HEALTH_CHECK_TOKEN=your-secret-token-here
#
#   Enable Cloudflare Turnstile or similar CAPTCHA:
#       CAPTCHA_DRIVER=turnstile
#       TURNSTILE_SITE_KEY=your-site-key
#       TURNSTILE_SECRET_KEY=your-secret-key
# ---------------------------------------------------------------------------
