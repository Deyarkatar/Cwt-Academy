includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 9
    paths:
        - app
        - routes
        - database/factories
        - database/seeders
        - tests
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        - '#Access to an undefined property Illuminate\\Database\\Eloquent\\Model::\$#'
        - '#Cannot access property \$value on string#'
        - '#\(string\) does not accept App\Enums\.*#'
        - '#\(int<0, max>\|null\) does not accept int\|string\|null#'
        - '#\(int<0, max>\|null\) does not accept int#'
        - '#Parameter \#\d+ \$haystack of method PHPUnit\\Framework\\Assert::assertString(Not)?ContainsString\(\) expects string, string\|false given#'
        - '#Parameter \#\d+ \$array of method PHPUnit\\Framework\\Assert::assertArray(Not)?HasKey\(\) expects array<mixed>\|ArrayAccess.*given#'
        - '#Cannot access offset .* on mixed#'
        - '#Parameter \#\d+ \$haystack of method PHPUnit\\Framework\\Assert::assertContains\(\) expects iterable, mixed given#'
        - '#Method Tests\\Feature\\Security\\CourseRequestWorkflowSecurityTest::createCourseRequestWithProof\(\) return type has no value type specified in iterable type array#'
        - '#Property App\\Models\\AuditLog::\$action \(string\) does not accept App\\Enums\\AuditAction::#'
